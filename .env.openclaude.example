# OpenClaude VS Code launcher profile
# Copy this file to .env.openclaude if you want workspace-local overrides:
#   cp .env.openclaude.example .env.openclaude
#
# The VS Code workspace settings already set:
#   CLAUDE_CODE_USE_OPENAI=1
#   OPENAI_MODEL=gpt-5.4
#
# If you already use the Codex CLI, OpenClaude will read ~/.codex/auth.json
# automatically and you can leave these unset.

# Optional explicit Codex auth overrides:
# CODEX_API_KEY=
# CHATGPT_ACCOUNT_ID=
# CODEX_AUTH_JSON_PATH=

# Optional Firecrawl key:
# Improves WebFetch for JS-rendered pages and provides a search fallback for
# non-Codex providers.
# FIRECRAWL_API_KEY=
